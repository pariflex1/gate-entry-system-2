{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" },
    { "source": "/client/(.*)", "destination": "/client/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}