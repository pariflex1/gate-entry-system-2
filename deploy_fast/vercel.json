{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/dist/(.*)", "destination": "/dist/$1" },
    { "source": "/assets/(.*)", "destination": "/dist/assets/$1" },
    { "source": "/admin/assets/(.*)", "destination": "/dist/admin/assets/$1" },
    { "source": "/client/assets/(.*)", "destination": "/dist/client/assets/$1" },
    { "source": "/admin/(.*)", "destination": "/dist/admin/index.html" },
    { "source": "/client/(.*)", "destination": "/dist/client/index.html" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ]
}