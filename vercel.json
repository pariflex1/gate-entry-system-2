{
    "version": 2,
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/admin/index.html"
        },
        {
            "source": "/client/(.*)",
            "destination": "/client/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}